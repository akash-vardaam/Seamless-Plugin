{
  "name": "seamless-wordpress-plugin",
  "version": "1.0.0",
  "description": "=== Seamless ===",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:production": "vite build --mode production",
    "preview": "vite preview",
    "test": "echo \"Error: no test specified\" && exit 1",
    "install-carbon-fields": "composer require htmlburger/carbon-fields",
    "package": "yarn build:production && cd .. && zip -r seamless-$(date +%Y%m%d-%H%M%S).zip seamless-wordpress-plugin -x '*/node_modules/*' '*/src/js/*' '*/src/css/*' '*/.git/*' '*/.vscode/*' '*/package.json' '*/package-lock.json' '*/yarn.lock' '*/vite.config.js' '*/.gitignore' '*.md' '!*/readme.md'",
    "package:check": "ls -lh ../seamless-*.zip && unzip -l ../seamless-*.zip | head -50"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vardaam-Web-Solutions-Pvt-Ltd/seamless-wordpress-plugin.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Vardaam-Web-Solutions-Pvt-Ltd/seamless-wordpress-plugin/issues"
  },
  "homepage": "https://github.com/Vardaam-Web-Solutions-Pvt-Ltd/seamless-wordpress-plugin#readme",
  "devDependencies": {
    "vite": "^7.2.4"
  },
  "dependencies": {
    "@toast-ui/calendar": "^2.1.3",
    "add-to-calendar-button": "^2.13.3",
    "jquery": "^3.7.1",
    "slick-carousel": "^1.8.1",
    "tui-code-snippet": "^2.3.3",
    "tui-date-picker": "^4.3.3",
    "tui-time-picker": "^2.1.6"
  },
  "overrides": {
    "dompurify": "^3.2.4"
  }
}
